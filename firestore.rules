rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // 0. Global Safety Net
    match /{document=**} {
      allow read, write: if false;
    }

    // --- Helpers ---
    function isSignedIn() {
      return request.auth != null;
    }

    function isVerified() {
      return isSignedIn(); // Relaxed to allow immediate access after Google login
    }


    function isValidId(id) {
      return id is string && id.size() <= 128 && id.matches('^[a-zA-Z0-9_\\-]+$');
    }

    function incoming() {
      return request.resource.data;
    }

    function existing() {
      return resource.data;
    }

    // --- Validation Blueprints ---

    function isValidUser(data) {
      return data.keys().hasAll(['uid', 'email', 'createdAt']) 
        && data.uid == request.auth.uid
        && data.email == request.auth.token.email
        && (data.get('age', 20) is number)
        && (data.get('weight', 70) is number)
        && (data.get('height', 170) is number)
        && (data.get('gender', 'other') in ['male', 'female', 'other']);
    }

    function isValidReading(data) {
      return data.keys().hasAll(['userId', 'systolic', 'diastolic', 'heartRate', 'timestamp'])
        && data.userId == request.auth.uid
        && data.systolic is number && data.systolic >= 10 && data.systolic <= 300
        && data.diastolic is number && data.diastolic >= 10 && data.diastolic <= 250
        && data.heartRate is number && data.heartRate >= 20 && data.heartRate <= 250
        && (data.get('stressLevel', 5) is number && data.stressLevel >= 1 && data.stressLevel <= 10)
        && (data.get('mood', '') is string && data.mood.size() <= 64)
        && (data.get('note', '') is string && data.note.size() <= 500);
    }

    // --- Collection Routes ---

    match /users/{userId} {
      allow get: if isVerified() && userId == request.auth.uid;
      allow create: if isVerified() && userId == request.auth.uid && isValidUser(incoming()) && incoming().createdAt == request.time;
      allow update: if isVerified() && userId == request.auth.uid 
        && incoming().uid == existing().uid
        && incoming().email == existing().email
        && incoming().createdAt == existing().createdAt
        && (
          incoming().diff(existing()).affectedKeys().hasOnly(['name', 'age', 'gender', 'weight', 'height'])
        );
    }

    match /readings/{readingId} {
      allow list: if isVerified() && resource.data.userId == request.auth.uid;
      allow get: if isVerified() && resource.data.userId == request.auth.uid;
      allow create: if isVerified() && isValidId(readingId) && isValidReading(incoming()) && incoming().timestamp == request.time;
      allow update: if isVerified() && resource.data.userId == request.auth.uid 
        && incoming().userId == existing().userId
        && (
          incoming().diff(existing()).affectedKeys().hasOnly(['stressLevel', 'mood', 'note'])
        );
      allow delete: if isVerified() && resource.data.userId == request.auth.uid;
    }
  }
}
